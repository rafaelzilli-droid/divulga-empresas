---
import HeroAnimation from "./HeroAnimation.astro";
import WhatsAppIcon from "./icons/WhatsAppIcon.astro";

const WA_GABRIEL = "https://wa.me/5517991087969";
---

<section
  class="hero relative overflow-hidden py-14 md:py-20 lg:py-24"
  id="topo"
  style="background: linear-gradient(180deg, var(--azul-soft) 0%, #ffffff 100%);"
>
  <div class="container-divulga">
    <div class="grid gap-10 lg:gap-14 items-center lg:grid-cols-[1.1fr_1fr]">
      <div class="hero-text">
        <div
          class="inline-flex items-center gap-2 bg-white border border-borda px-3.5 py-1.5 rounded-full text-[13px] font-medium text-texto-suave mb-5 shadow-[0_1px_3px_rgba(16,24,40,0.06)]"
        >
          <span class="w-2 h-2 bg-verde rounded-full pulse-dot"></span>
          mais de 800 empresas atendidas
        </div>

        <h1
          class="text-[34px] sm:text-[42px] lg:text-[52px] font-extrabold tracking-[-0.02em] leading-[1.12] mb-[18px] text-texto"
        >
          Quando procuram um negócio como o seu, o <span
            class="relative inline-block text-azul"
            >seu aparece.<span
              aria-hidden="true"
              class="absolute left-0 right-0 bottom-[2px] h-2 bg-amarelo opacity-[0.35] rounded -z-10"
            ></span></span
          >
        </h1>

        <p class="text-[17px] lg:text-[18px] text-texto-suave mb-7 max-w-[520px] leading-[1.6]">
          A Divulga cuida do seu perfil no Google e no Google Maps pra você ser encontrado por
          quem busca um negócio como o seu na sua cidade. Sem você precisar mexer em&nbsp;nada.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={WA_GABRIEL}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary-divulga inline-flex items-center gap-2.5 bg-whatsapp text-white px-7 py-4 rounded-xl text-base font-semibold"
          >
            <WhatsAppIcon size={20} />
            Falar no WhatsApp
          </a>
          <a
            href="#planos"
            class="btn-secondary-divulga inline-flex items-center gap-2 bg-white text-texto px-6 py-4 rounded-xl text-base font-medium border border-borda"
          >
            Ver planos
          </a>
        </div>
      </div>

      <div class="hero-visual">
        <HeroAnimation />
      </div>
    </div>
  </div>
</section>

<style>
  .btn-primary-divulga {
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.3);
    transition:
      transform 150ms,
      box-shadow 200ms,
      background-color 200ms;
  }
  .btn-primary-divulga:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(37, 211, 102, 0.4);
    background-color: var(--whatsapp-dark);
  }
  .btn-secondary-divulga {
    transition:
      border-color 200ms,
      background-color 200ms;
  }
  .btn-secondary-divulga:hover {
    border-color: var(--azul);
    background-color: var(--azul-soft);
  }
</style>
