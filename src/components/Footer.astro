---
import { Image } from "astro:assets";
import logo from "../assets/logo/divulga-logo.png";
---

<footer class="bg-noite text-white/80 pt-10 pb-7 text-sm">
  <div class="container-divulga">
    <div class="grid gap-7 mb-7 sm:grid-cols-[2fr_1fr_1fr]">
      <div>
        <div class="mb-4 inline-block">
          <Image
            src={logo}
            alt="Divulga Empresas — Marketing de Geolocalização"
            width={520}
            height={172}
            loading="lazy"
            class="h-12 w-auto bg-white/95 rounded-md px-2 py-1.5"
          />
        </div>
        <p class="text-white/70 leading-[1.7] text-[13px]">
          Especialistas em presença digital pra pequenos e médios negócios do interior.
        </p>
      </div>

      <div>
        <h4
          class="text-[13px] font-semibold text-white mb-3 uppercase tracking-[0.05em]"
        >
          Contato
        </h4>
        <a
          href="https://wa.me/5517991087969"
          target="_blank"
          rel="noopener noreferrer"
          class="block text-white/70 hover:text-white text-[13px] mb-1.5 transition-colors"
          >Gabriel — (17) 99108-7969</a
        >
        <a
          href="https://wa.me/5517991502287"
          target="_blank"
          rel="noopener noreferrer"
          class="block text-white/70 hover:text-white text-[13px] mb-1.5 transition-colors"
          >Carlos — (17) 99150-2287</a
        >
        <a
          href="https://wa.me/5517996513467"
          target="_blank"
          rel="noopener noreferrer"
          class="block text-white/70 hover:text-white text-[13px] transition-colors"
          >Suporte — (17) 99651-3467</a
        >
      </div>

      <div>
        <h4
          class="text-[13px] font-semibold text-white mb-3 uppercase tracking-[0.05em]"
        >
          Navegação
        </h4>
        <a
          href="#o-que-faz"
          class="block text-white/70 hover:text-white text-[13px] mb-1.5 transition-colors"
          >O que fazemos</a
        >
        <a
          href="#como-funciona"
          class="block text-white/70 hover:text-white text-[13px] mb-1.5 transition-colors"
          >Como funciona</a
        >
        <a
          href="#planos"
          class="block text-white/70 hover:text-white text-[13px] mb-1.5 transition-colors"
          >Planos</a
        >
        <a
          href="#faq"
          class="block text-white/70 hover:text-white text-[13px] mb-1.5 transition-colors"
          >Perguntas frequentes</a
        >
        <a
          href="#contato"
          class="block text-white/70 hover:text-white text-[13px] transition-colors"
          >Contato</a
        >
      </div>
    </div>
    <div class="border-t border-white/10 pt-5">
      <!-- Linha legal: links pras 3 páginas + abrir preferências de cookies -->
      <nav
        class="flex flex-wrap justify-center items-center gap-x-5 gap-y-2 mb-4 text-[13px]"
        aria-label="Links legais"
      >
        <a
          href="/politica-de-privacidade"
          class="text-white/70 hover:text-white transition-colors"
          >Política de Privacidade</a
        >
        <span class="text-white/30" aria-hidden="true">·</span>
        <a
          href="/termos-de-uso"
          class="text-white/70 hover:text-white transition-colors">Termos de Uso</a
        >
        <span class="text-white/30" aria-hidden="true">·</span>
        <a
          href="/politica-de-cookies"
          class="text-white/70 hover:text-white transition-colors"
          >Política de Cookies</a
        >
        <span class="text-white/30" aria-hidden="true">·</span>
        <button
          type="button"
          class="footer-consent-btn text-white/70 hover:text-white transition-colors"
          data-footer-consent
        >
          Preferências de cookies
        </button>
      </nav>

      <p
        class="text-[11px] text-white/40 leading-[1.55] mb-2 max-w-[760px] mx-auto text-center"
      >
        G.C DIVULGA EMPRESAS LTDA · CNPJ 64.597.498/0001-02 · Sede fiscal: Rua
        Luiz Pastorelli, 1788, Jardim Palmeiras, Potirendaba-SP, CEP 15.107-028
      </p>
      <p class="text-xs text-white/50 text-center">
        © 2026 Divulga Empresas · Marketing de Geolocalização · São José do Rio Preto-SP
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-consent-btn {
    background: transparent;
    border: 0;
    padding: 0;
    font: inherit;
    cursor: pointer;
    font-size: inherit;
  }
</style>

<script>
  // Botão "Preferências de cookies" no footer abre o modal do ConsentManager
  type ConsentApi = { open: () => void };
  type W = Window & { DivulgaConsent?: ConsentApi };
  document
    .querySelectorAll<HTMLButtonElement>("[data-footer-consent]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        (window as unknown as W).DivulgaConsent?.open();
      });
    });
</script>

