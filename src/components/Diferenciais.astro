---
const diferenciais = [
  {
    titulo: "Atendimento presencial",
    descricao:
      "Somos da região. A gente vai até o seu negócio. Cara a cara, do jeito que funciona no interior.",
    icon: "casa",
  },
  {
    titulo: "Time que conhece seu mercado",
    descricao:
      "Já atendemos marmorarias, padarias, oficinas, restaurantes e lojas de móveis. Sabemos como o seu funciona.",
    icon: "time",
  },
  {
    titulo: "Você não mexe em nada",
    descricao:
      "Fotos, postagens, ajustes, respostas. Você toca o negócio, a gente cuida da sua presença online.",
    icon: "check",
  },
  {
    titulo: "Relatório claro todo mês",
    descricao:
      "Nada de termo técnico. Um resumo simples do que aconteceu e do que vamos fazer no mês seguinte.",
    icon: "doc",
  },
];
---

<section class="py-16 lg:py-20">
  <div class="container-divulga reveal">
    <span
      class="inline-block bg-azul-soft text-azul px-3.5 py-1.5 rounded-full text-[13px] font-semibold mb-3.5"
      >Por que a Divulga</span
    >
    <h2
      class="text-[28px] lg:text-4xl font-bold tracking-[-0.02em] leading-[1.2] mb-3.5 max-w-[720px] text-texto"
    >
      O que a gente faz diferente.
    </h2>
    <p class="text-base lg:text-[17px] text-texto-suave max-w-[600px] mb-10">
      Tem muita empresa vendendo presença digital. Quase nenhuma faz do jeito que a&nbsp;gente&nbsp;faz.
    </p>

    <div class="grid gap-3.5 grid-cols-1 sm:grid-cols-2 reveal-stagger">
      {
        diferenciais.map((dif) => (
          <div class="flex gap-3.5 p-[22px] bg-white rounded-xl border border-borda">
            <div class="w-[42px] h-[42px] bg-azul-soft text-azul rounded-[10px] flex items-center justify-center shrink-0">
              {dif.icon === "casa" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="20"
                  height="20"
                  aria-hidden="true"
                >
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
              )}
              {dif.icon === "time" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="20"
                  height="20"
                  aria-hidden="true"
                >
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
              )}
              {dif.icon === "check" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="20"
                  height="20"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              )}
              {dif.icon === "doc" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="20"
                  height="20"
                  aria-hidden="true"
                >
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="16" y1="13" x2="8" y2="13" />
                  <line x1="16" y1="17" x2="8" y2="17" />
                  <polyline points="10 9 9 9 8 9" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="text-base font-semibold mb-1 text-texto">{dif.titulo}</h3>
              <p class="text-texto-suave text-sm leading-[1.55]">{dif.descricao}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
