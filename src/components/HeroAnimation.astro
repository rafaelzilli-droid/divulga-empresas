---
/* Mockup animado do Google que vive no hero.

   Sequência (loop):
     1. Aparece só o campo de busca vazio com cursor piscando.
     2. Texto "marmoraria perto de mim" é digitado letra-por-letra (~80ms cada).
     3. Após a busca "enviar", os cards de resultado entram com fade + slide-up.
     4. Segura ~6s no estado final, então reseta e recomeça.

   O JS roda no client. Em prefers-reduced-motion, o estado final é exibido direto. */
---

<div class="relative w-full max-w-[420px] mx-auto">
  <div
    class="phone-mock bg-white rounded-3xl p-4 border border-borda"
    style="box-shadow: var(--shadow-lg)"
    data-hero-anim
  >
    <div class="flex items-center gap-2 mb-3 pb-3 border-b border-borda">
      <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="#4285F4"
          d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
        ></path>
        <path
          fill="#34A853"
          d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
        ></path>
        <path
          fill="#FBBC05"
          d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
        ></path>
        <path
          fill="#EA4335"
          d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
        ></path>
      </svg>
      <div
        class="flex-1 bg-bg-suave px-3 py-2 rounded-[20px] text-[13px] text-texto-suave overflow-hidden whitespace-nowrap"
      >
        <span data-hero-typed></span><span class="typing-cursor" data-hero-cursor></span>
      </div>
    </div>

    <!-- Card de destaque (Marmoraria Bela Pedra) — slot pronto pra foto real -->
    <div
      class="biz-card-main p-3 rounded-xl bg-white border border-borda mb-2 transition-all duration-500 ease-out"
      data-hero-card="main"
      style="opacity: 0; transform: translateY(12px);"
    >
      <div
        class="hero-biz-img w-full h-[120px] rounded-lg mb-3 relative overflow-hidden"
        role="img"
        aria-label="Foto do estabelecimento Marmoraria Bela Pedra (placeholder)"
      >
      </div>
      <h4 class="text-[15px] font-semibold mb-1 text-texto">Marmoraria Bela Pedra</h4>
      <div class="flex items-center gap-1.5 text-[13px] text-texto-suave mb-1.5">
        <span class="text-amarelo">★★★★★</span>
        <span>4,9 · 87 avaliações</span>
      </div>
      <div class="text-xs text-texto-mais-suave flex flex-wrap gap-1.5">
        <span class="text-verde font-semibold">● Aberto</span>
        <span>· Fecha às 18h</span>
        <span>· Fernandópolis</span>
      </div>
    </div>

    <!-- Card secundário — concorrente sem otimização -->
    <div
      class="p-3 rounded-xl bg-white border border-borda transition-all duration-500 ease-out"
      data-hero-card="secondary"
      style="opacity: 0; transform: translateY(12px);"
    >
      <h4 class="text-sm font-semibold mb-1 text-texto opacity-60">Marmoraria São José</h4>
      <div class="flex items-center gap-1.5 text-[13px] text-texto-suave opacity-60">
        <span class="text-amarelo">★★★★☆</span>
        <span>4,2</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* Placeholder visual do card de destaque — fachada de comércio estilizada.
     Quando houver foto real, basta substituir o background por background-image: url(...) */
  .hero-biz-img {
    background: linear-gradient(135deg, #4a5365 0%, #2c3340 100%);
  }
  .hero-biz-img::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 50%, rgba(0, 0, 0, 0.3) 100%),
      linear-gradient(
        180deg,
        #5b8de8 0%,
        #5b8de8 35%,
        #c9a47c 35%,
        #c9a47c 75%,
        #6b5a47 75%
      );
  }
  .hero-biz-img::after {
    content: "";
    position: absolute;
    bottom: 25%;
    left: 20%;
    right: 20%;
    height: 35%;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.6) 0%,
      rgba(255, 255, 255, 0.6) 25%,
      transparent 25%,
      transparent 37.5%,
      rgba(0, 0, 0, 0.4) 37.5%,
      rgba(0, 0, 0, 0.4) 62.5%,
      transparent 62.5%,
      transparent 75%,
      rgba(255, 255, 255, 0.6) 75%
    );
    border-top: 2px solid #3d3429;
  }
</style>

<script>
  // Animação do mockup do Google.
  // Roda em loop até a aba ficar escondida (visibilitychange pausa pra economizar).
  const root = document.querySelector<HTMLElement>("[data-hero-anim]");
  if (root) {
    const typed = root.querySelector<HTMLSpanElement>("[data-hero-typed]");
    const cursor = root.querySelector<HTMLSpanElement>("[data-hero-cursor]");
    const cardMain = root.querySelector<HTMLElement>('[data-hero-card="main"]');
    const cardSecondary = root.querySelector<HTMLElement>('[data-hero-card="secondary"]');

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const QUERY = "marmoraria perto de mim";

    const showFinalState = () => {
      if (typed) typed.textContent = QUERY;
      if (cursor) cursor.style.display = "none";
      if (cardMain) {
        cardMain.style.opacity = "1";
        cardMain.style.transform = "translateY(0)";
      }
      if (cardSecondary) {
        cardSecondary.style.opacity = "1";
        cardSecondary.style.transform = "translateY(0)";
      }
    };

    const showInitialState = () => {
      if (typed) typed.textContent = "";
      if (cursor) cursor.style.display = "inline-block";
      if (cardMain) {
        cardMain.style.opacity = "0";
        cardMain.style.transform = "translateY(12px)";
      }
      if (cardSecondary) {
        cardSecondary.style.opacity = "0";
        cardSecondary.style.transform = "translateY(12px)";
      }
    };

    if (prefersReduced) {
      showFinalState();
    } else {
      const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

      const typeQuery = async () => {
        if (!typed) return;
        for (let i = 0; i <= QUERY.length; i++) {
          typed.textContent = QUERY.slice(0, i);
          await sleep(80);
        }
      };

      const loop = async () => {
        while (true) {
          showInitialState();
          await sleep(600);
          await typeQuery();
          await sleep(500);
          if (cardMain) {
            cardMain.style.opacity = "1";
            cardMain.style.transform = "translateY(0)";
          }
          await sleep(200);
          if (cardSecondary) {
            cardSecondary.style.opacity = "1";
            cardSecondary.style.transform = "translateY(0)";
          }
          await sleep(6500);
        }
      };

      loop();
    }
  }
</script>
