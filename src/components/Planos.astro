---
/* Seção de planos enxuta: um card único com título, lead e CTA WhatsApp.
   A composição completa dos planos é apresentada na conversa, não na página. */

import WhatsAppIcon from "./icons/WhatsAppIcon.astro";

const WA_PLANOS =
  "https://wa.me/5517991087969?text=Ol%C3%A1!%20Quero%20conhecer%20os%20planos%20da%20Divulga.";
---

<section class="py-16 lg:py-20 bg-bg-suave" id="planos">
  <div class="container-divulga reveal">
    <span
      class="inline-block bg-azul-soft text-azul px-3.5 py-1.5 rounded-full text-[13px] font-semibold mb-3.5"
      >Planos</span
    >
    <div
      class="bg-white border border-borda rounded-[20px] p-8 lg:p-12 max-w-[640px] mx-auto text-center"
    >
      <h2
        class="text-[24px] lg:text-[28px] font-bold tracking-[-0.02em] leading-[1.2] mb-3 text-texto"
      >
        Planos a partir de
        <span class="text-azul font-extrabold whitespace-nowrap"
          >R$&nbsp;59,90/mês</span
        >.
      </h2>
      <p class="text-base text-texto-suave leading-[1.55] mb-7">
        A gente monta o plano certo pro tamanho do seu negócio. Fale com a
        gente pra entender qual&nbsp;encaixa.
      </p>
      <a
        href={WA_PLANOS}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary-divulga inline-flex items-center justify-center gap-2.5 bg-whatsapp text-white px-7 py-4 rounded-xl text-base font-semibold"
      >
        <WhatsAppIcon size={20} />
        Falar com a gente
      </a>
    </div>
  </div>
</section>

<style>
  .btn-primary-divulga {
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.3);
    transition:
      transform 150ms,
      box-shadow 200ms,
      background-color 200ms;
  }
  .btn-primary-divulga:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(37, 211, 102, 0.4);
    background-color: var(--whatsapp-dark);
  }
</style>
