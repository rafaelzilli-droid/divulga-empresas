---
/* Carrossel infinito de logos de clientes da Divulga.

   Técnica: duplica o array de logos e anima a track horizontalmente até
   translateX(-50%). Como a 1ª e a 2ª metade são idênticas, no momento do
   reset (50% deslocado), o frame é visualmente igual ao início — loop
   perfeito sem "salto".

   Logos vêm de assets/fotos/clientes/<slug>.png via astro:assets. Se algum
   arquivo não existir, mostra fallback de texto com o nome da empresa pra
   manter a faixa preenchida.

   Pausa no hover. Em prefers-reduced-motion: layout em grid estático, sem
   animação. */

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

/* Source of truth dos clientes. Pra adicionar uma logo nova:
   1. Salvar o arquivo em assets/fotos/clientes/<slug>.<ext> (png/svg/jpg/jpeg/webp)
   2. Adicionar uma linha aqui com { slug, nome }
   Se o arquivo não existir, o card mostra o nome em texto como fallback. */
type Cliente = {
  slug: string;
  nome: string;
  /** Artigo do alt e do fallback ("a" / "o"). Default: "a". */
  artigo?: "a" | "o";
};

const clientes: Cliente[] = [
  { slug: "kmais", nome: "Kmais" },
  { slug: "panificadora-poti", nome: "Panificadora Poti" },
  { slug: "poti", nome: "Poti Cia. de Bebidas" },
  { slug: "levity", nome: "Levity" },
  { slug: "kinino", nome: "Kinino" },
  { slug: "ice-fest", nome: "Ice Fest" },
  { slug: "posto-brasilian", nome: "Posto Brasilian", artigo: "o" },
  { slug: "posto-chiesa", nome: "Posto Chiesa", artigo: "o" },
  { slug: "canaa-automoveis", nome: "Canaã Automóveis" },
  { slug: "via-frangus", nome: "Via Frangu's" },
  { slug: "mr-frangos", nome: "Mr. Frango's" },
  { slug: "urupemix", nome: "Urupemix" },
  // Slug com typo "cerevejaria" mantido propositalmente pra bater com o nome
  // do arquivo. O label "Cervejaria" segue grafia correta.
  { slug: "trieste-cerevejaria", nome: "Trieste Cervejaria" },
];

// Carrega TODAS as logos da pasta de uma vez. Aceita várias extensões pra
// suportar logos vindas em formatos diferentes (PNG, SVG, JPG, WEBP).
// Quando uma logo nova é adicionada, ela aparece aqui automaticamente —
// basta o slug bater com uma entrada do array acima.
const fotos = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/fotos/clientes/*.{png,svg,jpg,jpeg,webp}",
  { eager: true }
);
const fotoMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(fotos)) {
  const slug = path.match(/\/([^/]+)\.[^.]+$/)?.[1];
  if (slug) fotoMap[slug] = mod.default;
}

// Loga clientes sem foto no build pro dev saber o que ainda falta
const missing = clientes.filter((c) => !fotoMap[c.slug]);
if (missing.length > 0) {
  console.warn(
    `[Clientes] ${missing.length}/${clientes.length} logos sem PNG:`,
    missing.map((c) => `${c.slug}.png`).join(", ")
  );
}

// Duplica o array pra criar a faixa infinita (1ª e 2ª metade idênticas).
const faixa = [...clientes, ...clientes];
---

<section
  class="bg-white py-12 lg:py-20"
  aria-label="Empresas que já confiam na Divulga"
>
  <div class="container-divulga reveal">
    <h2
      class="text-base lg:text-[18px] font-medium text-texto-suave text-center mb-8"
    >
      Empresas que já confiam na Divulga
    </h2>

    <div class="marquee" data-marquee>
      <ul class="marquee-track" aria-hidden="true">
        {
          faixa.map((c, i) => {
            const foto = fotoMap[c.slug];
            const altPreposicao = c.artigo === "o" ? "do" : "da";
            const alt = `Logo ${altPreposicao} ${c.nome}`;
            const isDuplicate = i >= clientes.length;
            return (
              <li
                class:list={[
                  "marquee-item",
                  isDuplicate && "marquee-item--duplicate",
                ]}>
                {foto ? (
                  <Image
                    src={foto}
                    alt={alt}
                    width={300}
                    height={150}
                    loading="lazy"
                    decoding="async"
                    class="logo-img"
                  />
                ) : (
                  <span class="logo-fallback">{c.nome}</span>
                )}
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .marquee {
    overflow: hidden;
    position: relative;
    /* fade nas bordas pra entrada/saída suave das logos */
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }
  .marquee-track {
    display: flex;
    gap: 24px;
    width: max-content;
    list-style: none;
    padding: 0;
    margin: 0;
    animation: marquee-scroll 90s linear infinite;
  }
  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }
  .marquee-item {
    flex: 0 0 auto;
    height: 80px;
    min-width: 160px;
    background: white;
    border: 1px solid var(--borda);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .logo-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .logo-fallback {
    font-size: 14px;
    font-weight: 600;
    color: var(--texto-suave);
    text-align: center;
    line-height: 1.2;
  }
  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 640px) {
    .marquee-item {
      height: 64px;
      min-width: 140px;
      padding: 12px;
    }
    .marquee-track {
      gap: 16px;
      animation-duration: 70s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 12px;
    }
    /* sem animação, não precisa duplicar — escondemos a 2ª metade */
    .marquee-item--duplicate {
      display: none;
    }
  }
</style>
