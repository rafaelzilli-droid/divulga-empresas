---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Fotos reais dos depoimentos via astro:assets.
// Fallback pras iniciais caso algum arquivo não exista.
const depoimentosFotos = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/fotos/depoimentos/*.png",
  { eager: true }
);

const depoimentos = [
  {
    quote:
      "A empresa que cuida do meu Google é a Divulga. Eles cuidam de tudo: fotos, endereço, atualização. É um diferencial que muda o jogo.",
    nome: "Alessandro Marcelo",
    negocio: "Starcar Estética Automotiva · São José do Rio Preto",
    iniciais: "AM",
    foto: depoimentosFotos["../../assets/fotos/depoimentos/alessandro.png"]
      ?.default,
    alt: "Alessandro Marcelo, cliente da Divulga",
  },
  {
    quote:
      "A Divulga colocou minha loja na frente das pessoas certas, no lugar certo. Depois de três meses, a Florvie chegou em primeiro lugar nas buscas. Pra quem tem loja física, isso faz toda diferença.",
    nome: "Isabella Ruiz",
    negocio: "Florvie Moda Fitness · São José do Rio Preto",
    iniciais: "IR",
    foto: depoimentosFotos["../../assets/fotos/depoimentos/isabella.png"]
      ?.default,
    alt: "Isabella Ruiz, cliente da Divulga",
  },
  {
    quote:
      "Desde o início da parceria com a Divulga, percebi melhora significativa no posicionamento da minha clínica no Google. O diferencial é o acompanhamento mensal e as estratégias aplicadas. Recomendo com total confiança.",
    nome: "Dayane Tavares",
    negocio: "Day Tavares Estética · São José do Rio Preto",
    iniciais: "DT",
    foto: depoimentosFotos["../../assets/fotos/depoimentos/dayane.png"]?.default,
    alt: "Dayane Tavares, cliente da Divulga",
  },
];
---

<section class="py-16 lg:py-20">
  <div class="container-divulga reveal">
    <h2
      class="text-[28px] lg:text-4xl font-bold tracking-[-0.02em] leading-[1.2] mb-3.5 max-w-[720px] text-texto"
    >
      Quem confia, fica.
    </h2>
    <p class="text-base lg:text-[17px] text-texto-suave max-w-[600px] mb-10">
      Depoimentos de quem já mudou a presença digital do negócio com&nbsp;a&nbsp;Divulga.
    </p>

    <div
      class="grid gap-3.5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger"
    >
      {
        depoimentos.map((d) => (
          <div class="bg-white border border-borda rounded-[20px] p-6">
            <p class="text-[15px] text-texto leading-[1.6] mb-5 quote-divulga">
              {d.quote}
            </p>
            <div class="flex items-center gap-3">
              {d.foto ? (
                <div class="w-11 h-11 rounded-full overflow-hidden shrink-0 border border-borda">
                  <Image
                    src={d.foto}
                    alt={d.alt}
                    width={88}
                    height={88}
                    loading="lazy"
                    class="w-full h-full object-cover"
                  />
                </div>
              ) : (
                <div
                  class="w-11 h-11 rounded-full bg-gradient-to-br from-azul to-azul-dark text-white flex items-center justify-center font-bold text-sm shrink-0"
                  aria-hidden="true"
                >
                  {d.iniciais}
                </div>
              )}
              <div>
                <div class="font-semibold text-sm text-texto">{d.nome}</div>
                <div class="text-[13px] text-texto-suave">{d.negocio}</div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .quote-divulga::before {
    content: '"';
    font-size: 36px;
    color: var(--azul);
    line-height: 0;
    margin-right: 4px;
    vertical-align: -10px;
  }
</style>
