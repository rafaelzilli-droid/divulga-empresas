---
/* Layout base — single source of truth pra todas as meta tags, OG, Twitter,
   structured data, favicons.

   URL base: vem de Astro.site (configurado em astro.config.mjs via SITE_URL).
   Pra trocar o domínio quando o cliente comprar o próprio, basta definir
   a env var SITE_URL — nada mais precisa mudar. */
import "../styles/global.css";

import ConsentManager from "../components/consent/ConsentManager.astro";

interface Props {
  title?: string;
  description?: string;
  ogDescription?: string;
  ogImage?: string;
  canonical?: string;
  /** JSON-LD adicional (ex: WebPage) renderizado depois do @graph principal. */
  extraSchema?: object;
}

const DEFAULT_TITLE =
  "Divulga Empresas — Marketing de Geolocalização no Google | São José do Rio Preto";

// Description longa pra <meta name="description"> (SEO)
const DEFAULT_DESCRIPTION =
  "A Divulga cuida do seu perfil no Google e no Google Maps pra você ser encontrado por quem busca um negócio como o seu. Atendimento presencial em São José do Rio Preto e todo o noroeste paulista. Mais de 800 empresas atendidas.";

// Description mais curta pra Open Graph / Twitter (preview de link social)
const DEFAULT_OG_DESCRIPTION =
  "A Divulga cuida do seu perfil no Google pra você ser encontrado por quem busca um negócio como o seu. +800 empresas atendidas.";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogDescription = DEFAULT_OG_DESCRIPTION,
  ogImage = "/og-image.png",
  canonical,
  extraSchema,
} = Astro.props;

// Google Analytics 4 — só carrega se o ID estiver definido
const GA4_ID = import.meta.env.PUBLIC_GA4_ID ?? "";
const META_PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID ?? "";

// URLs absolutas — Astro.site vem do config (https://divulgaempresasmarketing.com.br
// por padrão, ou o que estiver em SITE_URL)
const canonicalURL =
  canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
const logoURL = new URL("/assets/logo/divulga-logo.png", Astro.site).toString();
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "";

// Schema.org @graph com 3 nodes: LocalBusiness, Service (com Offers dos planos)
// e FAQPage. Texto das perguntas espelha exatamente a seção FAQ visual.
const businessId = `${siteOrigin}/#business`;

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": businessId,
      name: "Divulga Empresas",
      legalName: "G.C DIVULGA EMPRESAS LTDA",
      alternateName: "Divulga Empresas — Marketing de Geolocalização",
      description:
        "Empresa especializada em gestão de perfil no Google Meu Negócio e Google Maps para pequenos e médios negócios do interior paulista. Atendimento presencial em São José do Rio Preto e região.",
      url: `${siteOrigin}/`,
      logo: logoURL,
      image: ogImageURL,
      telephone: "+5517991087969",
      email: "agenciadivulgaempresas@gmail.com",
      taxID: "64.597.498/0001-02",
      priceRange: "R$$",
      // address = endereço FISCAL registrado no CNPJ (Potirendaba).
      // A operação comercial fica em São José do Rio Preto — representada
      // pelo geo abaixo e pela copy do site.
      address: {
        "@type": "PostalAddress",
        streetAddress: "Rua Luiz Pastorelli, 1788",
        addressLocality: "Potirendaba",
        addressRegion: "SP",
        postalCode: "15107-028",
        addressCountry: "BR",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: -20.8113,
        longitude: -49.3758,
      },
      areaServed: [
        { "@type": "Place", name: "Noroeste Paulista" },
        { "@type": "City", name: "São José do Rio Preto" },
        { "@type": "City", name: "Fernandópolis" },
        { "@type": "City", name: "Votuporanga" },
        { "@type": "City", name: "Potirendaba" },
        { "@type": "City", name: "Jales" },
        { "@type": "City", name: "Cardoso" },
      ],
      sameAs: [],
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "08:00",
        closes: "18:00",
      },
    },
    {
      "@type": "Service",
      name: "Gestão de Perfil no Google Meu Negócio",
      provider: { "@id": businessId },
      description:
        "Criação, otimização e gestão contínua de perfis no Google Meu Negócio e Google Maps para negócios locais.",
      areaServed: { "@type": "Place", name: "Noroeste Paulista" },
      offers: {
        "@type": "AggregateOffer",
        lowPrice: "59.90",
        priceCurrency: "BRL",
        priceSpecification: {
          "@type": "UnitPriceSpecification",
          price: "59.90",
          priceCurrency: "BRL",
          unitText: "MONTHLY",
        },
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "O que é o Google Meu Negócio?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "O Google Meu Negócio é uma ferramenta gratuita do Google que permite que sua empresa apareça nas buscas e no Google Maps. Quando alguém procura um negócio como o seu na sua região, é o perfil no Google Meu Negócio que mostra suas fotos, horário, endereço e avaliações.",
          },
        },
        {
          "@type": "Question",
          name: "Como a Divulga ajuda minha empresa a aparecer no Google?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "A gente cria e otimiza o seu perfil no Google Meu Negócio com fotos profissionais, vídeos, informações completas e cuida da atualização contínua. Todo mês monitoramos como seu negócio está aparecendo e ajustamos pra você ser encontrado por mais pessoas na sua região.",
          },
        },
        {
          "@type": "Question",
          name: "Quais cidades a Divulga atende?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Atendemos todo o noroeste paulista, incluindo São José do Rio Preto, Votuporanga, Fernandópolis, Potirendaba, Jales, Cardoso e cidades vizinhas. Nosso atendimento é presencial, com visitas no seu negócio.",
          },
        },
        {
          "@type": "Question",
          name: "Como funciona o monitoramento mensal?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Todo mês você recebe um relatório simples mostrando quantas pessoas viram seu negócio no Google, quantas te ligaram, quantas pediram rota até sua loja. A partir disso, ajustamos o perfil pra continuar melhorando os resultados.",
          },
        },
        {
          "@type": "Question",
          name: "Qual o investimento dos planos?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Nossos planos começam em R$ 59,90 por mês e variam conforme a necessidade do seu negócio — quantidade de fotos, vídeos, visitas presenciais e recursos extras. Fale com a gente no WhatsApp pra ver qual encaixa melhor.",
          },
        },
      ],
    },
  ],
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    {/*
      BOOTSTRAP DO CONSENT MODE v2 — precisa rodar antes do GA4 e antes de
      qualquer outra ferramenta de rastreamento. Define dataLayer/gtag,
      seta consent default DENIED (LGPD-first) e aplica de imediato qualquer
      consent salvo no localStorage. is:inline garante que o navegador
      execute literalmente no topo do head, sem hoisting/defer do Astro.
    */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      window.gtag = gtag;

      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        functionality_storage: "denied",
        personalization_storage: "denied",
        security_storage: "granted",
        wait_for_update: 500,
      });

      // Se houver consentimento salvo, aplica de imediato (antes do GA4 enviar nada)
      try {
        var __c = localStorage.getItem("divulga_consent_v1");
        if (__c) {
          var p = JSON.parse(__c).preferences;
          if (p) {
            gtag("consent", "update", {
              analytics_storage: p.analytics ? "granted" : "denied",
              ad_storage: p.marketing ? "granted" : "denied",
              ad_user_data: p.marketing ? "granted" : "denied",
              ad_personalization: p.marketing ? "granted" : "denied",
              functionality_storage: p.functionality ? "granted" : "denied",
              personalization_storage: p.functionality ? "granted" : "denied",
            });
          }
        }
      } catch (_) {}
    </script>

    {
      GA4_ID && (
        <>
          <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`} />
          <script is:inline define:vars={{ GA4_ID }}>
            {`
              gtag('js', new Date());
              gtag('config', GA4_ID, {
                anonymize_ip: true,
                allow_google_signals: false
              });
            `}
          </script>
        </>
      )
    }

    {/*
      META PIXEL — desativado por padrão. Pra ativar:
      1. Defina PUBLIC_META_PIXEL_ID no .env (ou nas env vars do Vercel)
      2. Descomente o bloco abaixo
      3. Descomente o bloco `if (typeof w.fbq === "function") { ... }` em
         ConsentManager.astro pra repassar o consent ao Pixel
    */}
    {/*
    {META_PIXEL_ID && (
      <script is:inline define:vars={{ META_PIXEL_ID }}>
        {`
          !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
          fbq('consent', 'revoke');
          fbq('init', META_PIXEL_ID);
          fbq('track', 'PageView');
        `}
      </script>
    )}
    */}

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta http-equiv="content-language" content="pt-BR" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Divulga Empresas" />
    <meta
      name="keywords"
      content="marketing de geolocalização, google meu negócio, perfil google empresa, gestão google maps, são josé do rio preto, votuporanga, jales, fernandópolis, potirendaba, interior paulista, presença digital pequenas empresas, divulga empresas"
    />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1"
    />
    <meta name="googlebot" content="index, follow" />

    <!-- Geo tags pra busca local -->
    <meta name="geo.region" content="BR-SP" />
    <meta name="geo.placename" content="São José do Rio Preto" />
    <meta name="geo.position" content="-20.8113;-49.3758" />
    <meta name="ICBM" content="-20.8113, -49.3758" />

    <!-- Theme color (PWA / mobile) -->
    <meta name="theme-color" content="#2A6FDB" />
    <meta name="msapplication-TileColor" content="#2A6FDB" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png"
    />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Divulga Empresas" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Logo da Divulga Empresas" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Logo da Divulga Empresas" />

    <!-- Schema.org structured data: LocalBusiness + Service (+ Offers) + FAQPage -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schemaGraph)}
    />

    {/* Schema adicional fornecido pela página (ex: WebPage nas páginas legais) */}
    {
      extraSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(extraSchema)}
        />
      )
    }
  </head>
  <body>
    <slot />
    <ConsentManager />
  </body>
</html>
