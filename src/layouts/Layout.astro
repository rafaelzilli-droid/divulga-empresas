---
/* Layout base — single source of truth pra todas as meta tags, OG, Twitter,
   structured data, favicons.

   URL base: vem de Astro.site (configurado em astro.config.mjs via SITE_URL).
   Pra trocar o domínio quando o cliente comprar o próprio, basta definir
   a env var SITE_URL — nada mais precisa mudar. */
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const DEFAULT_TITLE =
  "Divulga Empresas — Marketing de Geolocalização no Google | Fernandópolis-SP";
const DEFAULT_DESCRIPTION =
  "A Divulga Empresas cuida do seu perfil no Google e no Google Maps pra você ser encontrado por quem busca um negócio como o seu. +800 empresas atendidas no noroeste paulista.";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage = "/og-image.png",
  canonical,
} = Astro.props;

// URLs absolutas — Astro.site vem do config (https://divulga-empresas.vercel.app
// por padrão, ou o que estiver em SITE_URL)
const canonicalURL =
  canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
const logoURL = new URL("/assets/logo/divulga-logo.png", Astro.site).toString();
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "";

// Schema.org @graph com 3 nodes: LocalBusiness, Service (com Offers dos planos)
// e FAQPage. Texto das perguntas espelha exatamente a seção FAQ visual.
const businessId = `${siteOrigin}/#business`;

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": businessId,
      name: "Divulga Empresas",
      alternateName: "Divulga Empresas — Marketing de Geolocalização",
      description:
        "Empresa especializada em gestão de perfil no Google Meu Negócio e Google Maps para pequenos e médios negócios do interior paulista.",
      url: `${siteOrigin}/`,
      logo: logoURL,
      image: ogImageURL,
      telephone: "+5517991087969",
      priceRange: "R$ 689 - R$ 2.285",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Fernandópolis",
        addressRegion: "SP",
        addressCountry: "BR",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: -20.2841,
        longitude: -50.2467,
      },
      areaServed: [
        { "@type": "Place", name: "Noroeste Paulista" },
        { "@type": "City", name: "Fernandópolis" },
        { "@type": "City", name: "Votuporanga" },
        { "@type": "City", name: "São José do Rio Preto" },
        { "@type": "City", name: "Potirendaba" },
        { "@type": "City", name: "Jales" },
        { "@type": "City", name: "Cardoso" },
      ],
      sameAs: [],
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "08:00",
        closes: "18:00",
      },
    },
    {
      "@type": "Service",
      name: "Gestão de Perfil no Google Meu Negócio",
      provider: { "@id": businessId },
      description:
        "Criação, otimização e gestão contínua de perfis no Google Meu Negócio e Google Maps para negócios locais.",
      areaServed: { "@type": "Place", name: "Noroeste Paulista" },
      offers: [
        {
          "@type": "Offer",
          name: "Plano Padrão",
          price: "689",
          priceCurrency: "BRL",
          priceSpecification: {
            "@type": "UnitPriceSpecification",
            price: "689",
            priceCurrency: "BRL",
            unitText: "ANNUAL",
          },
        },
        {
          "@type": "Offer",
          name: "Plano Plus",
          price: "869",
          priceCurrency: "BRL",
        },
        {
          "@type": "Offer",
          name: "Plano Premium",
          price: "1359",
          priceCurrency: "BRL",
        },
        {
          "@type": "Offer",
          name: "Plano Diamante",
          price: "2285",
          priceCurrency: "BRL",
        },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "O que é o Google Meu Negócio?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "O Google Meu Negócio é uma ferramenta gratuita do Google que permite que sua empresa apareça nas buscas e no Google Maps. Quando alguém procura um negócio como o seu na sua região, é o perfil no Google Meu Negócio que mostra suas fotos, horário, endereço e avaliações.",
          },
        },
        {
          "@type": "Question",
          name: "Como a Divulga ajuda minha empresa a aparecer no Google?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "A gente cria e otimiza o seu perfil no Google Meu Negócio com fotos profissionais, vídeos, informações completas e cuida da atualização contínua. Todo mês monitoramos como seu negócio está aparecendo e ajustamos pra você ser encontrado por mais pessoas na sua região.",
          },
        },
        {
          "@type": "Question",
          name: "Quais cidades a Divulga atende?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Atendemos todo o noroeste paulista, incluindo Fernandópolis, Votuporanga, São José do Rio Preto, Potirendaba, Jales, Cardoso e cidades vizinhas. Nosso atendimento é presencial, com visitas no seu negócio.",
          },
        },
        {
          "@type": "Question",
          name: "Como funciona o monitoramento mensal?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Todo mês você recebe um relatório simples mostrando quantas pessoas viram seu negócio no Google, quantas te ligaram, quantas pediram rota até sua loja. A partir disso, ajustamos o perfil pra continuar melhorando os resultados.",
          },
        },
        {
          "@type": "Question",
          name: "Qual o investimento dos planos?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Temos quatro planos anuais: Padrão (R$ 689), Plus (R$ 869), Premium (R$ 1.359) e Diamante (R$ 2.285). A diferença está na quantidade de fotos, vídeos, visitas presenciais e recursos extras como QR Code em placa e site profissional. Fale com a gente no WhatsApp pra ver qual encaixa melhor no seu negócio.",
          },
        },
      ],
    },
  ],
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Divulga Empresas" />
    <meta
      name="keywords"
      content="Google Meu Negócio, Google Maps, marketing local, geolocalização, Fernandópolis, noroeste paulista, perfil empresa Google, SEO local interior"
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Geo tags pra busca local -->
    <meta name="geo.region" content="BR-SP" />
    <meta name="geo.placename" content="Fernandópolis" />
    <meta name="geo.position" content="-20.2841;-50.2467" />
    <meta name="ICBM" content="-20.2841, -50.2467" />

    <!-- Theme color (PWA / mobile) -->
    <meta name="theme-color" content="#2A6FDB" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png"
    />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Divulga Empresas" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Logo da Divulga Empresas — Marketing de Geolocalização no Google"
    />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta
      name="twitter:image:alt"
      content="Logo da Divulga Empresas — Marketing de Geolocalização no Google"
    />

    <!-- Schema.org structured data: LocalBusiness + Service (+ Offers) + FAQPage -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schemaGraph)}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
