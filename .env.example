# Variáveis de ambiente do projeto Divulga Empresas
#
# Copie este arquivo pra .env e ajuste os valores conforme necessário.
# Em produção (Vercel), defina-os em Project Settings → Environment Variables.
#
# IMPORTANTE: variáveis começando com PUBLIC_ são expostas ao client (browser).
# Não coloque secrets aqui — só IDs públicos (Google Analytics, Meta Pixel, etc).

# URL pública do site (Astro.site). Sobrescreve o default em astro.config.mjs.
# Se vazio, usa https://divulgaempresasmarketing.com.br
SITE_URL=

# Google Analytics 4 Measurement ID
# Quando vazio, o GA4 não é carregado (útil em dev/preview).
PUBLIC_GA4_ID=G-4FV1N8PM5Z

# Meta (Facebook) Pixel ID
# Quando vazio, o Pixel não é carregado.
# Pra ativar: preencha com o ID (ex: 1234567890) e descomente o bloco
# correspondente em src/layouts/Layout.astro e em src/components/consent/
# ConsentManager.astro.
PUBLIC_META_PIXEL_ID=
